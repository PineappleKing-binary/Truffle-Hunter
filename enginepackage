LUA = lua
PACKER = tools/package_compiler.lua

ENGINE_ROOT = Lua/Engine
BUILD_DIR = game/packages

ENGINE_PACKAGE = $(BUILD_DIR)/a_engine1.package


# Build engine virtual filesystem package
all: $(ENGINE_PACKAGE)


$(ENGINE_PACKAGE): $(shell find $(ENGINE_ROOT) -type f)
	mkdir -p $(BUILD_DIR)
	$(LUA) $(PACKER) \
		--input $(ENGINE_ROOT) \
		--output $(ENGINE_PACKAGE)


# Remove generated package
clean:
	rm -rf $(ENGINE_PACKAGE)


# Rebuild everything
rebuild: clean all


.PHONY: all clean rebuild
